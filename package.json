{
  "name": "alpha",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:agent": "cd ai-agent && .\\venv\\Scripts\\uvicorn app.main:app --reload --port 8000",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:agent\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
