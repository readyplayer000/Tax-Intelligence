{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://taxai-backend.onrender.com/api/:path*"
    },
    {
      "source": "/agent/:path*",
      "destination": "https://taxai-agent.onrender.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
